# Copy this file to .env.local and fill in your Warren mailbox settings.
# Use EMAIL_MODE=mock to keep testing without sending real email.

EMAIL_MODE=real
EMAIL_FROM="Your Name <you@meetwarren.com>"

# SMTP sends outbound emails.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@meetwarren.com
SMTP_PASS=your-app-password-or-mailbox-password

# IMAP reads unread inbound replies.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=you@meetwarren.com
IMAP_PASS=your-app-password-or-mailbox-password

# Optional template variables.
UGC_SENDER_NAME=Isa
UGC_MEETING_LINK=https://calendar.google.com/
UGC_DOCX_PATH=/Users/keremyilmaz/Downloads/UGC Messages (1).docx
